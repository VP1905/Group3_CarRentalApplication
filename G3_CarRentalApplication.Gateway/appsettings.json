{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "GatewayAccess": {
    "InternalSecret": "MY_GATEWAY_SECRET_KEY"
  },
  "ReverseProxy": {
    "Routes": {
      "customers-route": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/gateway/customers/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/customers" },
          {
            "RequestHeader": "X-Internal-Gateway",
            "Set": "MY_GATEWAY_SECRET_KEY"
          }
        ]
      },
      "vehicles-route": {
        "ClusterId": "vehicles-cluster",
        "Match": {
          "Path": "/gateway/vehicles/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/vehicles" },
          {
            "RequestHeader": "X-Internal-Gateway",
            "Set": "MY_GATEWAY_SECRET_KEY"
          }
        ]
      },
      "reservations-route": {
        "ClusterId": "reservations-cluster",
        "Match": {
          "Path": "/gateway/reservations/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/reservations" },
          {
            "RequestHeader": "X-Internal-Gateway",
            "Set": "MY_GATEWAY_SECRET_KEY"
          }
        ]
      },
      "maintenance-route": {
        "ClusterId": "maintenance-cluster",
        "Match": {
          "Path": "/gateway/maintenance/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/gateway/maintenance" },
          {
            "RequestHeader": "X-Internal-Gateway",
            "Set": "MY_GATEWAY_SECRET_KEY"
          }
        ]
      }
    },
    "Clusters": {
      "customers-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7156/"
          }
        }
      },
      "vehicles-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7245/"
          }
        }
      },
      "reservations-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7151/"
          }
        }
      },
      "maintenance-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7191/"
          }
        }
      }
    }
  }
}