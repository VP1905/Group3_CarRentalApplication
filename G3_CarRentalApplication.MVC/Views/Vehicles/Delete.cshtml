@model G3_CarRentalApplication.MVC.Models.VehicleViewModel

@{
    ViewData["Title"] = "Delete Vehicle";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Vehicle</h3>
        </div>
        <div class="card-body">
            <p>Are you sure you want to delete this vehicle?</p>

            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Vehicle Code</dt>
                <dd class="col-sm-9">@Model.VehicleCode</dd>

                <dt class="col-sm-3">Location</dt>
                <dd class="col-sm-9">@Model.LocationId</dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@Model.VehicleType</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input asp-for="Id" type="hidden" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>