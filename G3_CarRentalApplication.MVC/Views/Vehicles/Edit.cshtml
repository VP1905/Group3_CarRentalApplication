@model G3_CarRentalApplication.MVC.Models.VehicleViewModel

@{
    ViewData["Title"] = "Edit Vehicle";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <h3 class="mb-0">Edit Vehicle</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="VehicleCode" class="form-label"></label>
                    <input asp-for="VehicleCode" class="form-control" />
                    <span asp-validation-for="VehicleCode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LocationId" class="form-label"></label>
                    <input asp-for="LocationId" class="form-control" />
                    <span asp-validation-for="LocationId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="VehicleType" class="form-label"></label>
                    <input asp-for="VehicleType" class="form-control" />
                    <span asp-validation-for="VehicleType" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option>Available</option>
                        <option>Reserved</option>
                        <option>Rented</option>
                        <option>UnderService</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-warning text-dark">Update</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}