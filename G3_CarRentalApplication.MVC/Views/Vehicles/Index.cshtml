@model IEnumerable<G3_CarRentalApplication.MVC.Models.VehicleViewModel>

@{
    ViewData["Title"] = "Vehicles";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Vehicles</h2>
        <a asp-action="Create" class="btn btn-primary">Add Vehicle</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Vehicle Code</th>
                <th>Location</th>
                <th>Type</th>
                <th>Status</th>
                <th style="width:240px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.VehicleCode</td>
                        <td>@item.LocationId</td>
                        <td>@item.VehicleType</td>
                        <td>@item.Status</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">No vehicles found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>