@model G3_CarRentalApplication.MVC.Models.ReservationHistoryViewModel

@{
    ViewData["Title"] = "Reservation Details";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h3 class="mb-0">Reservation Details</h3>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Reservation ID</dt>
                <dd class="col-sm-9">@Model.ReservationId</dd>

                <dt class="col-sm-3">Customer</dt>
                <dd class="col-sm-9">@Model.CustomerFullName</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.ReservationStartDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.ReservationEndDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Reservation Status</dt>
                <dd class="col-sm-9">@Model.ReservationStatus</dd>
            </dl>

            <a asp-action="History" class="btn btn-secondary">Back</a>
        </div>
    </div>
</div>