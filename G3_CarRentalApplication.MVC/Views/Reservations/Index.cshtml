@model G3_CarRentalApplication.MVC.Models.ReservationPageViewModel

@{
    ViewData["Title"] = "Create Reservation";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Create Reservation</h3>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form asp-action="Index" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Reservation.CustomerId" class="form-label"></label>
                    <select asp-for="Reservation.CustomerId" asp-items="Model.Customers" class="form-select">
                        <option value="">-- Select Customer --</option>
                    </select>
                    <span asp-validation-for="Reservation.CustomerId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Reservation.VehicleId" class="form-label"></label>
                    <select asp-for="Reservation.VehicleId" asp-items="Model.Vehicles" class="form-select">
                        <option value="">-- Select Vehicle --</option>
                    </select>
                    <span asp-validation-for="Reservation.VehicleId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Reservation.ReservationStartDate" class="form-label"></label>
                    <input asp-for="Reservation.ReservationStartDate" type="date" class="form-control" />
                    <span asp-validation-for="Reservation.ReservationStartDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Reservation.ReservationEndDate" class="form-label"></label>
                    <input asp-for="Reservation.ReservationEndDate" type="date" class="form-control" />
                    <span asp-validation-for="Reservation.ReservationEndDate" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Create Reservation</button>
                <a asp-action="History" class="btn btn-secondary">View History</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}