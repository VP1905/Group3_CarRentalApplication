@model G3_CarRentalApplication.MVC.Models.ReservationPageViewModel

@{
    ViewData["Title"] = "Create Reservation";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h2 class="mb-0">Create Reservation</h2>
        </div>

        <div class="card-body p-4">
            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="alert alert-success">@Model.Message</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }

            <form asp-action="Index" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Reservation.CustomerId" class="form-label fw-semibold"></label>
                    <select asp-for="Reservation.CustomerId" asp-items="Model.Customers" class="form-select">
                        <option value="">-- Select Customer --</option>
                    </select>
                    <span asp-validation-for="Reservation.CustomerId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Reservation.VehicleId" class="form-label fw-semibold"></label>
                    <select asp-for="Reservation.VehicleId" asp-items="Model.Vehicles" class="form-select">
                        <option value="">-- Select Vehicle --</option>
                    </select>
                    <span asp-validation-for="Reservation.VehicleId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Reservation.ReservationStartDate" class="form-label fw-semibold"></label>
                        <input asp-for="Reservation.ReservationStartDate" class="form-control" type="date" />
                        <span asp-validation-for="Reservation.ReservationStartDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Reservation.ReservationEndDate" class="form-label fw-semibold"></label>
                        <input asp-for="Reservation.ReservationEndDate" class="form-control" type="date" />
                        <span asp-validation-for="Reservation.ReservationEndDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary px-4">Reserve</button>
                    <a asp-controller="Reservations" asp-action="History" class="btn btn-outline-secondary px-4">
                        View History
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}