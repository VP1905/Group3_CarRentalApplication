@model G3_CarRentalApplication.MVC.Models.ReservationHistoryViewModel

@{
    ViewData["Title"] = "Delete Reservation";
}

<div class="container mt-4">
    <div class="card shadow-sm border-danger">
        <div class="card-header bg-danger text-white">
            <h3 class="mb-0">Delete Reservation</h3>
        </div>
        <div class="card-body">
            <p>Are you sure you want to delete this reservation?</p>

            <dl class="row">
                <dt class="col-sm-3">Reservation ID</dt>
                <dd class="col-sm-9">@Model.ReservationId</dd>

                <dt class="col-sm-3">Customer</dt>
                <dd class="col-sm-9">@Model.CustomerFullName</dd>

                <dt class="col-sm-3">Vehicle Code</dt>
                <dd class="col-sm-9">@Model.VehicleCode</dd>

                <dt class="col-sm-3">Vehicle Type</dt>
                <dd class="col-sm-9">@Model.VehicleType</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.ReservationStartDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.ReservationEndDate.ToString("yyyy-MM-dd")</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input asp-for="ReservationId" type="hidden" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="History" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>