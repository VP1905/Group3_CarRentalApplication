@model IEnumerable<G3_CarRentalApplication.MVC.Models.ReservationHistoryViewModel>

@{
    ViewData["Title"] = "Reservation History";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-dark text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h2 class="mb-0">Reservation History</h2>
            <a asp-controller="Reservations" asp-action="Index" class="btn btn-light btn-sm">Back</a>
        </div>

        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-primary">
                        <tr>
                            <th>Customer Name</th>
                            <th>Vehicle Code</th>
                            <th>Vehicle Type</th>
                            <th>Location</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Reservation Status</th>
                            <th>Vehicle Status</th> 
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.CustomerFullName</td>
                                    <td>@item.VehicleCode</td>
                                    <td>@item.VehicleType</td>
                                    <td>@item.LocationId</td>
                                    <td>@item.ReservationStartDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.ReservationEndDate.ToString("yyyy-MM-dd")</td>
                                    <td>@item.ReservationStatus</td>
                                    <td>@item.VehicleStatus</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted">No reservation records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>