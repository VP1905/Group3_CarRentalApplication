@model IEnumerable<G3_CarRentalApplication.MVC.Models.ReservationHistoryViewModel>

@{
    ViewData["Title"] = "Reservation History";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Reservation History</h2>
        <a asp-action="Index" class="btn btn-primary">Add Reservation</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Vehicle</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ReservationId</td>
                                <td>@item.CustomerFullName</td>
                                <td>@item.VehicleCode</td>
                                <td>@item.ReservationStartDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.ReservationEndDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.ReservationStatus</td>
                                <td>
                                    <div class="action-buttons">

                                        <a asp-action="Details"
                                           asp-route-id="@item.ReservationId"
                                           class="btn-action btn-info-custom">
                                            Details
                                        </a>

                                        @if (item.ReservationStatus == "Confirmed")
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.ReservationId" />
                                                <input type="hidden" name="status" value="Active" />
                                                <button type="submit" class="btn-action btn-primary-custom">
                                                    Activate
                                                </button>
                                            </form>

                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.ReservationId" />
                                                <input type="hidden" name="status" value="Cancelled" />
                                                <button type="submit" class="btn-action btn-danger-custom">
                                                    Cancel
                                                </button>
                                            </form>
                                        }

                                        @if (item.ReservationStatus == "Active")
                                        {
                                            <form asp-action="UpdateStatus" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.ReservationId" />
                                                <input type="hidden" name="status" value="Completed" />
                                                <button type="submit" class="btn-action btn-dark-custom">
                                                    Complete
                                                </button>
                                            </form>
                                        }

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No reservations found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>