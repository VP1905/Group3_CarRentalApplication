@model IEnumerable<G3_CarRentalApplication.MVC.Models.ReservationHistoryViewModel>

@{
    ViewData["Title"] = "Reservation History";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Reservation History</h2>
        <a asp-action="Index" class="btn btn-primary">Add Reservation</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Customer</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Reservation Status</th>
                        <th style="width:240px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ReservationId</td>
                                <td>@item.CustomerFullName</td>
                                <td>@item.ReservationStartDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.ReservationEndDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.ReservationStatus</td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@item.ReservationId" class="btn btn-sm btn-info text-white">Details</a>
                                        <a asp-action="Edit" asp-route-id="@item.ReservationId" class="btn btn-sm btn-warning text-dark">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@item.ReservationId" class="btn btn-sm btn-danger">Delete</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No reservations found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>