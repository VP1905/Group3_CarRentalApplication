@model IEnumerable<G3_CarRentalApplication.MVC.Models.MaintenanceViewModel>

@{
    ViewData["Title"] = "Maintenance Records";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Maintenance Records</h2>
        <a asp-action="Create" class="btn btn-primary">Add Record</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Vehicle ID</th>
                <th>Repair Date</th>
                <th>Description</th>
                <th>Cost</th>
                <th>Performed By</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.VehicleId</td>
                    <td>@item.RepairDate.ToString("yyyy-MM-dd")</td>
                    <td>@item.Description</td>
                    <td>@item.Cost</td>
                    <td>@item.PerformedBy</td>
                </tr>
            }
        </tbody>
    </table>
</div>