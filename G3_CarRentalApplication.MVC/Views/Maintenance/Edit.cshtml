@model G3_CarRentalApplication.MVC.Models.MaintenanceViewModel

@{
    ViewData["Title"] = "Edit Maintenance Record";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <h3 class="mb-0">Edit Maintenance Record</h3>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="VehicleId" class="form-label"></label>
                    <input asp-for="VehicleId" class="form-control" />
                    <span asp-validation-for="VehicleId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="RepairDate" class="form-label"></label>
                    <input asp-for="RepairDate" type="date" class="form-control" />
                    <span asp-validation-for="RepairDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Cost" class="form-label"></label>
                    <input asp-for="Cost" class="form-control" />
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PerformedBy" class="form-label"></label>
                    <input asp-for="PerformedBy" class="form-control" />
                    <span asp-validation-for="PerformedBy" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-warning text-dark">Update</button>
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}